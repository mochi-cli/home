# Copy to .env.local and fill in real values.
# Never commit .env.local — it is gitignored.

# --- Site ---------------------------------------------------------------------
# Canonical site URL. Drives OG image URLs, sitemap, robots.txt, JSON-LD.
# No trailing slash.
NEXT_PUBLIC_SITE_URL=https://mochi-cli.com

# Twitter / X handle including the @. Leave blank to omit twitter:site/creator.
NEXT_PUBLIC_TWITTER_HANDLE=

# --- SEO verification (optional) ----------------------------------------------
# From Google Search Console → HTML tag method → content="..." value.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
# From Yandex.Webmaster.
NEXT_PUBLIC_YANDEX_VERIFICATION=

# --- Polar checkout -----------------------------------------------------------
# Polar access token — Server-only. Get from Polar dashboard → Settings → Access Tokens.
POLAR_ACCESS_TOKEN=

# Where Polar redirects the user after successful checkout. {CHECKOUT_ID} is substituted.
POLAR_SUCCESS_URL=https://mochi-cli.com/success?checkout_id={CHECKOUT_ID}

# Public product ID for the Pro plan. Get from Polar dashboard → Products → your Pro product → ID.
NEXT_PUBLIC_POLAR_PRO_PRODUCT_ID=
